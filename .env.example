# ── Compagnon Configuration ──────────────────────────────────
# Copy to .env and fill in your values

# Required: Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-...

# Required: Telegram Bot Token (from @BotFather)
TELEGRAM_TOKEN=123456:ABC...

# Optional: Restrict to specific Telegram user IDs (comma-separated)
TELEGRAM_ALLOWED_USERS=

# Optional: Model override (default: claude-sonnet-4-20250514)
COMPAGNON_MODEL=claude-sonnet-4-20250514

# Optional: Working directory (default: $HOME)
COMPAGNON_WORK_DIR=

# Optional: Memory directory (default: ~/.compagnon/memory)
COMPAGNON_MEMORY_DIR=

# Optional: Path to custom instructions file
COMPAGNON_INSTRUCTIONS_FILE=

# Optional: MCP servers config (JSON)
# Example:
# COMPAGNON_MCP_SERVERS={"filesystem":{"command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/home/user"],"transport":"stdio"}}
COMPAGNON_MCP_SERVERS=
